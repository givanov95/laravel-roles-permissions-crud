{
    "name": "givanov95/laravel-roles-permissions-crud",
    "description": "Admin CRUD for spatie/laravel-permission roles & permissions on Laravel + Inertia, with a matching Vue 3 frontend (@givanov95/vue-roles-permissions-crud).",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "roles", "permissions", "rbac", "spatie", "inertia", "vue", "crud"],
    "authors": [
        {
            "name": "Georgi Ivanov",
            "email": "joroz95@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/validation": "^11.0|^12.0|^13.0",
        "inertiajs/inertia-laravel": "^1.0|^2.0",
        "spatie/laravel-permission": "^6.0|^7.0"
    },
    "require-dev": {
        "givanov95/laravel-git-hooks": "^0.1.0",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "post-install-cmd": [
            "@php -r \"if (is_dir('.git/hooks') && file_exists('pre-commit')) { @unlink('.git/hooks/pre-commit'); @symlink('../../pre-commit', '.git/hooks/pre-commit'); @chmod('pre-commit', 0755); }\""
        ],
        "post-update-cmd": [
            "@php -r \"if (is_dir('.git/hooks') && file_exists('pre-commit')) { @unlink('.git/hooks/pre-commit'); @symlink('../../pre-commit', '.git/hooks/pre-commit'); @chmod('pre-commit', 0755); }\""
        ]
    },
    "autoload": {
        "psr-4": {
            "Givanov95\\RolesPermissionsCrud\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Givanov95\\RolesPermissionsCrud\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Givanov95\\RolesPermissionsCrud\\RolesPermissionsCrudServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "givanov95/laravel-git-hooks": true
        }
    }
}
